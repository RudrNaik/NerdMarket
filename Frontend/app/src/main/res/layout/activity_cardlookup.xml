<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".MainActivity"
    android:background="#2A1B3D"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/cardlookup_to_main_button"
            android:layout_width="70dp"
            android:layout_height="54dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginEnd="10dp"
            android:background="@drawable/baseline_home_24" />
    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Card Lookup"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="20dp"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        tools:ignore="HardcodedText"/>

        <ImageView
            android:id="@+id/Search_camera_btn"
            android:layout_width="70dp"
            android:layout_height="59dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="10dp"
            android:src="@android:drawable/ic_menu_camera" />

</FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/SearchText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SRC:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffffff"/>

        <EditText
            android:id="@+id/card_search_field"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <Button
            android:id="@+id/card_search_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Look up"
            android:textSize="16sp"
            android:textColor="#ffffff"/>

    </LinearLayout>
        <Button
            android:id="@+id/cardLookup_tobiggestmovers_btn"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="To Biggest Movers"
            android:layout_marginTop="7dp"
            android:textColor="#ffffff"
            android:textSize="20sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/cardLookup_card_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Card View -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#0B1f3a">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Image -->
            <ImageView
                android:id="@+id/card_image"
                android:layout_width="160dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp"
                android:scaleType="fitCenter"
                android:contentDescription="Card Image"/>

            <com.github.mikephil.charting.charts.CandleStickChart
                android:id="@+id/candleStick"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <!-- Name -->
            <TextView
                android:id="@+id/card_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name: —"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp"/>

            <!-- Name Edit -->
            <EditText
                android:id="@+id/card_name_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Card Name"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="18sp"
                android:visibility="gone"
                android:layout_marginBottom="6dp"/>

            <!-- Type -->
            <TextView
                android:id="@+id/card_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type: —"
                android:textSize="15sp"
                android:textColor="#3AA6FF"
                android:layout_marginBottom="4dp"/>

            <!-- Card Type Edit -->
            <EditText
                android:id="@+id/card_type_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Card Type"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="15sp"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <!-- Card Set -->
            <TextView
                android:id="@+id/card_set"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set: —"
                android:textSize="15sp"
                android:textColor="#3AA6FF"
                android:layout_marginBottom="4dp"/>

            <!-- Card Set Edit -->
            <EditText
                android:id="@+id/card_set_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Card Set"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="15sp"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <!-- Rarity -->
            <TextView
                android:id="@+id/card_rarity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rarity: —"
                android:textSize="15sp"
                android:textColor="#3AA6FF"
                android:layout_marginBottom="4dp"/>

            <!-- Rarity Edit -->
            <EditText
                android:id="@+id/card_rarity_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Card Rarity"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="15sp"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <!-- Price -->
            <TextView
                android:id="@+id/card_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price: —"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2e7d32"
                android:layout_marginBottom="4dp"/>

            <!-- Price Edit -->
            <EditText
                android:id="@+id/card_price_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Price"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="16sp"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <!-- Save and Edit Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/card_edit_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edit"
                    android:textColor="#ffffff"
                    android:backgroundTint="#1565C0"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/card_save_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save"
                    android:textColor="#ffffff"
                    android:backgroundTint="#2e7d32"
                    android:visibility="gone"
                    android:layout_marginStart="4dp"/>

                <Button
                    android:id="@+id/card_addTobinder_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Add To Binder"
                    android:textColor="#ffffff"
                    android:backgroundTint="#1565C0"
                    android:layout_marginEnd="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>


</androidx.appcompat.widget.LinearLayoutCompat>