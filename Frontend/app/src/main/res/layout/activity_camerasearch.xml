<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/cameraSearch_previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:implementationMode="compatible" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/cardBox"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@android:color/transparent"
                app:layout_constraintWidth_percent="0.8"
                app:layout_constraintDimensionRatio="2.5:3.5"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/topShade"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#99000000"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/cardBox"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/bottomShade"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#99000000"
                app:layout_constraintTop_toBottomOf="@id/cardBox"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/leftShade"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#99000000"
                app:layout_constraintTop_toTopOf="@id/cardBox"
                app:layout_constraintBottom_toBottomOf="@id/cardBox"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardBox" />

            <View
                android:id="@+id/rightShade"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#99000000"
                app:layout_constraintTop_toTopOf="@id/cardBox"
                app:layout_constraintBottom_toBottomOf="@id/cardBox"
                app:layout_constraintStart_toEndOf="@id/cardBox"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/cardFrame"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/card_frame"
                app:layout_constraintTop_toTopOf="@id/cardBox"
                app:layout_constraintBottom_toBottomOf="@id/cardBox"
                app:layout_constraintStart_toStartOf="@id/cardBox"
                app:layout_constraintEnd_toEndOf="@id/cardBox" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <ImageButton
        android:id="@+id/cameraSearch_camera_capture_btn"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/photo_capture_button"
        android:src="@android:color/transparent"
        android:contentDescription="Capture"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>