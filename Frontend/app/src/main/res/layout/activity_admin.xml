<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/gradient_background"
    tools:context=".MainActivity"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/logo_image_main"
        tools:srcCompat="@drawable/nerdmarket_logo"
        android:layout_marginTop="40dp"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:transitionName="logo_image_welcome"
        />

    <TextView
        android:id="@+id/admin_main_username_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Panel"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="100dp"
        android:textSize="30sp"
        android:textColor="#ffffff">
    </TextView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/admin_to_main_btn"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Back to main"
                android:textColor="#ffffff"
                android:textSize="20sp" />

            <Button
                android:id="@+id/admin_to_priceCrud_btn"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Price CRUD"
                android:textColor="#ffffff"
                android:textSize="20sp" />

            <Button
                android:id="@+id/admin_unlock_btn"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Unlock Account"
                android:textSize="20sp"
                android:textColor="#ffffff">
            </Button>

            <LinearLayout
                android:layout_width="250dp"
                android:id = "@+id/admin_unlock_container"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/admin_unlock_searchBox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID:"
                        android:textColor="#ffffff"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/admin_unlock_ID_searchField"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/admin_unlockAccount_btn"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="5dp"
                        android:text="Unlock"
                        android:textColor="#ffffff"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>


            <Button
                android:id="@+id/admin_activate_deactivate_btn"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Activate/Deactivate Account"
                android:textSize="20sp"
                android:textColor="#ffffff">
            </Button>

            <LinearLayout
        android:layout_width="250dp"
        android:id = "@+id/admin_activate_deactivate_container"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/admin_activate_deactivate_searchBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID:"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/admin_activate_deactivate_search_field"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="text"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/admin_activate_btn"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:text="Activate"
                android:textColor="#ffffff"
                android:textSize="12sp" />

            <Button
                android:id="@+id/admin_deactivate_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="Deactivate"
                android:textColor="#ffffff"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

            <Button
        android:id="@+id/admin_promote_demote_btn"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Promote/Demote Account"
        android:textSize="20sp"
        android:textColor="#ffffff">
    </Button>

            <LinearLayout
                android:layout_width="250dp"
                android:id = "@+id/admin_promote_demote_container"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <LinearLayout
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/admin_promote_demote_searchBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID:"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/admin_promote_demote_field"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="text"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
                <LinearLayout
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                android:id="@+id/admin_promote_btn"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:text="Promote"
                android:textColor="#ffffff"
                android:textSize="12sp" />

                    <Button
                android:id="@+id/admin_demote_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="Demote"
                android:textColor="#ffffff"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>


            <Button
        android:id="@+id/admin_delete_other_account_btn"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Delete Accounts"
        android:textSize="20sp"
        android:textColor="#ffffff">
    </Button>

            <LinearLayout
                android:layout_width="250dp"
                android:id = "@+id/admin_delete_container"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/admin_delete_searchBox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID:"
                        android:textColor="#ffffff"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/admin_delete_field"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/admin_delete_btn"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="5dp"
                        android:layout_gravity="center"
                        android:text="Delete Account"
                        android:textColor="#ffffff"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/admin_create_notif_btn"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Create Notification"
                android:textSize="20sp"
                android:textColor="#ffffff"/>

            <LinearLayout
                android:id="@+id/admin_create_notif_container"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Type (e.g. GENERAL):"
                    android:textColor="#ffffff"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/admin_notif_type_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="GENERAL"
                    android:inputType="text"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Title:"
                    android:textColor="#ffffff"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/admin_notif_title_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Notification title"
                    android:inputType="text"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message:"
                    android:textColor="#ffffff"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/admin_notif_message_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Notification message"
                    android:inputType="textMultiLine"
                    android:lines="3"
                    android:gravity="top"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Schedule (optional // year-month-day-Hours:Mins:Secs):"
                    android:textColor="#ffffff"
                    android:textSize="12sp"/>

                <EditText
                    android:id="@+id/admin_notif_scheduledat_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="2026-04-10T08:00:00"
                    android:inputType="text"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="14sp"/>

                <Button
                    android:id="@+id/admin_send_notif_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Send Notification"
                    android:textColor="#ffffff"
                    android:textSize="14sp"/>

            </LinearLayout>

            <Button
        android:id="@+id/admin_showAllAccounts_btn"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Show All Accounts"
        android:textColor="#ffffff"
        android:textSize="20sp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/account_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:layout_marginTop="24dp"
                        android:visibility="gone"
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#0B1f3a">
                        <LinearLayout
                            android:id="@+id/admin_account_cardDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/admin_account_cardDetail_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:layout_marginBottom="6dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </ScrollView>

        </LinearLayout>
    </ScrollView>



</androidx.appcompat.widget.LinearLayoutCompat>